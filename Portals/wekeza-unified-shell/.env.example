# Wekeza Unified Shell - Environment Variables

# API Backend Configuration
VITE_API_URL=http://localhost:8080
VITE_API_TIMEOUT=30000

# Authentication Mode
# Set to "mock" for testing without backend
# Set to "real" for production with backend JWT
VITE_AUTH_MODE=mock

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENVIRONMENT=development

# Optional: For production deployment, override these:
# VITE_API_URL=https://api.wekeza.bank
# VITE_AUTH_MODE=real
# VITE_ENABLE_MOCK_DATA=false
# VITE_ENVIRONMENT=production
